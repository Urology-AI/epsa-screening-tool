# Copy this file to .env.local and fill in your values.
# Never commit .env.local to the repository.

# Supabase — the anon key is safe to expose; RLS policies control access.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# PIN for /admin fallback (used only when Supabase is not configured)
VITE_CLINICAL_ADMIN_PIN=change-me

# Cloudflare Worker URL for REDCap proxy
VITE_REDCAP_PROXY_URL=https://epsa-redcap-proxy.your-account.workers.dev
