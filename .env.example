# Copy this file to .env.local and fill in your values.
# Never commit .env.local to the repository.

# Turso database (cloud SQLite) — use a database-scoped token, not a root token
VITE_TURSO_URL=libsql://your-db-name.turso.io
VITE_TURSO_AUTH_TOKEN=your-turso-auth-token

# Azure AD (Entra ID) — required for /admin login
VITE_AZURE_CLIENT_ID=your-application-client-id
VITE_AZURE_TENANT_ID=your-directory-tenant-id

# Cloudflare Worker URL for REDCap proxy
VITE_REDCAP_PROXY_URL=https://epsa-redcap-proxy.your-account.workers.dev
