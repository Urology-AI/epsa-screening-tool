# ─── Microsoft SSO (required) ────────────────────────────────────────────────
# Get these from portal.azure.com → Azure Active Directory → App registrations
# → [your app] → Overview
VITE_MSAL_CLIENT_ID=<Application (client) ID from Azure portal>
VITE_MSAL_TENANT_ID=<Directory (tenant) ID from Azure portal>

# ─── Firebase (still used for Firestore data — not for auth) ─────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Local dev emulators (optional) ──────────────────────────────────────────
VITE_USE_AUTH_EMULATOR=false
VITE_USE_FIRESTORE_EMULATOR=false
